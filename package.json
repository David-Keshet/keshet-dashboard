{
  "name": "keshet-dashboard-system",
  "version": "1.0.0",
  "description": "Multi-business print shop dashboard with N8N integration",
  "main": "dashboard-server.js",
  "scripts": {
    "start": "node dashboard-server.js",
    "tunnel": "node ngrok-tunnel.js",
    "bot": "node n8n-scripts/telegram-bot.js",
